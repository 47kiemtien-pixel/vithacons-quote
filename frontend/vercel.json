{
    "rewrites": [
        {
            "source": "/bao-gia/(assets|images)/(.*)",
            "destination": "/$1/$2"
        },
        {
            "source": "/bao-gia/:match*",
            "destination": "/index.html"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}